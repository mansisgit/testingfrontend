package com.socialmedia.friendship.entity;

import jakarta.persistence.*;

@Entity
@Table(name = "Friends")
public class Friendship {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    @Column(name = "friendshipID")
    private Integer friendshipId;

    // This implements: FOREIGN KEY (userID1) REFERENCES Users(userID)
    @ManyToOne
    @JoinColumn(name = "userID1", referencedColumnName = "userID")
    private User user1;

    // This implements: FOREIGN KEY (userID2) REFERENCES Users(userID)
    @ManyToOne
    @JoinColumn(name = "userID2", referencedColumnName = "userID")
    private User user2;

    @Enumerated(EnumType.STRING)
    private FriendStatus status;

    public Friendship() {}

    // Updated Getters and Setters to use the 'User' object
    public User getUser1() { return user1; }
    public void setUser1(User user1) { this.user1 = user1; }

    public User getUser2() { return user2; }
    public void setUser2(User user2) { this.user2 = user2; }

    public Integer getFriendshipId() { return friendshipId; }
    public void setFriendshipId(Integer friendshipId) { this.friendshipId = friendshipId; }

    public FriendStatus getStatus() { return status; }
    public void setStatus(FriendStatus status) { this.status = status; }
    
    public enum FriendStatus {
        PENDING,
        ACCEPTED
    }
}
